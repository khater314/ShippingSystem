@model TbCountryDTO

<div class="col-12 grid-margin stretch-card">
    <div class="card">
        <div class="card-body">
            <h4 class="card-title">@ResShared.Form_Title_Country</h4>
            <p class="card-description">@ResShared.Form_Description_Country</p>
            <form class="forms-sample" asp-controller="Country" asp-action="Edit" method="post">

                <div class="form-group">
                    <label for="CountryAname">@ResShared.Lbl_CountryAname</label>
                    <input type="text" class="form-control" id="CountryAname"
                           placeholder="@ResShared.Plh_CountryAname"
                           name="CountryAname" asp-for="CountryAname"
                           asp-route-id="@Model.CountryAname">
                           <span asp-validation-for="CountryAname" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label for="CountryEname">@ResShared.Lbl_CountryEname</label>
                    <input type="text" class="form-control" id="CountryEname"
                           placeholder="@ResShared.Plh_CountryEname"
                           name="CountryEname" asp-for="CountryEname"
                           asp-route-id="@Model.CountryEname">
                           <span asp-validation-for="CountryEname" class="text-danger"></span>
                </div>

                <button type="submit" class="btn btn-gradient-primary me-2">@ResShared.Btn_Submit</button>
                <a asp-action="Index" class="btn btn-light">@ResShared.Btn_Cancel</a>
            </form>
        </div>
    </div>
</div>
@section PluginStyles
{
    <link rel="stylesheet" href="~/admin/vendors/select2/select2.min.css">
    <link rel="stylesheet" href="~/admin/vendors/select2-bootstrap-theme/select2-bootstrap.min.css">
}
@section PluginScripts
{
    <script src="~/admin/vendors/select2/select2.min.js"></script>
    <script src="~/admin/vendors/typeahead.js/typeahead.bundle.min.js"></script>
}
@section CustomScripts
{
    <script src="~/admin/js/file-upload.js"></script>
    <script src="~/admin/js/typeahead.js"></script>
    <script src="~/admin/js/select2.js"></script>
}